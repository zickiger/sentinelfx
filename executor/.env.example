# ══════════════════════════════════════════════════
# SentinelFX Executor Bridge — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════

# TradingView webhook security token — must match backend WEBHOOK_SECRET
WEBHOOK_SECRET=sentinel_secret_change_me

# MetaTrader 5 credentials (Windows only — leave blank for simulation mode)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# Prop firm / account settings
PROP_FIRM=Topstep SIM
ACCOUNT_SIZE=100000

# Risk limits — tune to match your prop firm rules
DD_LIMIT_PCT=4.5
MAX_CONTRACTS=3
RISK_PER_TRADE=0.5
CONSISTENCY_PCT=30.0

# Anti-detection: randomise entry by 1-2 ticks
ANTI_DETECT=true

# Path to executor SQLite database
EXECUTOR_DB=data/executor.db

# Server port
PORT=8080
