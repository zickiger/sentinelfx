//@version=6
// ══════════════════════════════════════════════════════════════
// SMC ORDER BLOCK STRATEGY
// Generated by Architect Agent — 2026-04-27 23:48 UTC
// Signal ID:    preset_ob
// Alpha Score:  0.900
// Market:       ES/NQ
// Timeframe:    H1
// Entry Logic:  50% OB retrace
// SL Logic:     Below OB
// ══════════════════════════════════════════════════════════════
strategy("SMC Order Block [H1]",
     overlay=true,
     initial_capital=100000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract,
     commission_value=2.0)


// ══════════════════════════════════════════════════════════════
// PROP FIRM RISK ENGINE  — injected by Architect Agent
// Compatible: FTMO · Topstep · MyForexFunds · The5%ers
// ══════════════════════════════════════════════════════════════

// ── Prop Firm Inputs ──────────────────────────────────────────
var g_risk = "Prop Firm Risk"
dd_limit_pct      = input.float(4.5,  "Daily DD Limit %",        group=g_risk, minval=0.5,  maxval=10.0,  step=0.1)
max_loss_pct      = input.float(10.0, "Max Total Loss %",         group=g_risk, minval=1.0,  maxval=20.0,  step=0.5)
risk_per_trade    = input.float(0.5,  "Risk Per Trade %",         group=g_risk, minval=0.1,  maxval=3.0,   step=0.1)
consistency_pct   = input.float(30.0, "Max Single Day % of Obj.", group=g_risk, minval=10.0, maxval=100.0, step=5.0)
anti_detect       = input.bool(true,  "Anti-Detection Mode",      group=g_risk)
account_size      = input.float(100000, "Account Size ($)",       group=g_risk, minval=1000)

// ── Daily DD Tracking ─────────────────────────────────────────
var float day_start_equity = strategy.initial_capital
var float daily_dd         = 0.0
var bool  kill_switch      = false

is_new_day = ta.change(time("D")) != 0
if is_new_day
    day_start_equity := strategy.equity
    kill_switch      := false

daily_dd    := (day_start_equity - strategy.equity) / day_start_equity * 100
total_dd    = (strategy.initial_capital - strategy.equity) / strategy.initial_capital * 100

// Arm kill switch
if daily_dd >= dd_limit_pct or total_dd >= max_loss_pct
    kill_switch := true
    strategy.close_all(comment="KILL_SWITCH")

// ── Position Sizing ───────────────────────────────────────────
f_position_size(sl_ticks, tick_value) =>
    risk_dollars = account_size * (risk_per_trade / 100)
    sl_value     = sl_ticks * tick_value
    sl_value > 0 ? math.floor(risk_dollars / sl_value) : 1

// ── Anti-Detection: randomise entry by ±1-2 ticks ────────────
f_anti_detect_offset() =>
    anti_detect ? (math.random(0, 1) > 0.5 ? syminfo.mintick : -syminfo.mintick) : 0.0


// ══════════════════════════════════════════════════════════════
// ORDER BLOCK DETECTION
// ══════════════════════════════════════════════════════════════
var g_ob = "Order Block Settings"
ob_lookback      = input.int(10,   "OB Lookback Bars",    group=g_ob, minval=3,  maxval=50)
ob_entry_fib     = input.float(0.5,"Entry Fib Level",     group=g_ob, minval=0.1, maxval=1.0, step=0.1)
min_impulse_mult = input.float(1.5,"Min Impulse Mult",    group=g_ob, minval=1.0, maxval=5.0, step=0.1)
ob_invalidate    = input.bool(true, "Invalidate on Close Through", group=g_ob)
require_fvg      = input.bool(false,"Require FVG Confluence",      group=g_ob)

var g_sl = "Stop Loss / Take Profit"
sl_buffer_ticks  = input.int(2,  "SL Buffer (ticks)",  group=g_sl, minval=0, maxval=20)
rr_ratio         = input.float(2.0, "R:R Ratio",       group=g_sl, minval=0.5, maxval=10.0, step=0.5)
use_trailing_sl  = input.bool(false,"Use Trailing SL",  group=g_sl)
trail_pct        = input.float(0.3, "Trail %",          group=g_sl, minval=0.1, maxval=2.0, step=0.1)

// ── Impulse Detection ─────────────────────────────────────────
f_is_impulse(i) =>
    body      = math.abs(close[i] - open[i])
    prev_body = math.abs(close[i+1] - open[i+1])
    body > prev_body * min_impulse_mult

// ── OB Identification ─────────────────────────────────────────
f_bullish_ob(i) =>
    // Last bearish candle before bullish impulse
    close[i] < open[i] and
    close[i-1] > open[i-1] and
    f_is_impulse(i-1)

f_bearish_ob(i) =>
    // Last bullish candle before bearish impulse
    close[i] > open[i] and
    close[i-1] < open[i-1] and
    f_is_impulse(i-1)

// ── FVG Filter (optional confluence) ─────────────────────────
f_has_fvg_in_range(top, bot) =>
    result = false
    for i = 1 to 5
        bull_fvg = low[i] > high[i+2]
        bear_fvg = high[i] < low[i+2]
        if bull_fvg or bear_fvg
            result := true
    result

// ── OB Zone Arrays ────────────────────────────────────────────
var float[] ob_top   = array.new_float()
var float[] ob_bot   = array.new_float()
var bool[]  ob_bull  = array.new_bool()
var bool[]  ob_valid = array.new_bool()
var int[]   ob_bar   = array.new_int()

// Scan for new OBs each bar
for i = 1 to ob_lookback
    if f_bullish_ob(i)
        fvg_ok = not require_fvg or f_has_fvg_in_range(high[i], low[i])
        if fvg_ok
            array.push(ob_top,   high[i])
            array.push(ob_bot,   low[i])
            array.push(ob_bull,  true)
            array.push(ob_valid, true)
            array.push(ob_bar,   bar_index - i)
    if f_bearish_ob(i)
        fvg_ok = not require_fvg or f_has_fvg_in_range(high[i], low[i])
        if fvg_ok
            array.push(ob_top,   high[i])
            array.push(ob_bot,   low[i])
            array.push(ob_bull,  false)
            array.push(ob_valid, true)
            array.push(ob_bar,   bar_index - i)

// Invalidate OBs on close through
if ob_invalidate
    for i = 0 to array.size(ob_valid) - 1
        if array.get(ob_valid, i)
            if array.get(ob_bull, i) and close < array.get(ob_bot, i)
                array.set(ob_valid, i, false)
            if not array.get(ob_bull, i) and close > array.get(ob_top, i)
                array.set(ob_valid, i, false)

// ══════════════════════════════════════════════════════════════
// ENTRY LOGIC
// ══════════════════════════════════════════════════════════════
long_signal  = false
short_signal = false
entry_price  = close
sl_price     = close
tp_price     = close

for i = 0 to array.size(ob_valid) - 1
    if array.get(ob_valid, i) and not kill_switch
        top  = array.get(ob_top,  i)
        bot  = array.get(ob_bot,  i)
        bull = array.get(ob_bull, i)
        mid  = bot + (top - bot) * ob_entry_fib
        buf  = sl_buffer_ticks * syminfo.mintick + f_anti_detect_offset()

        // Long: price returns to OB between bot and fib level
        if bull and close <= mid and close >= bot and strategy.position_size == 0
            long_signal := true
            entry_price := close
            sl_price    := bot - buf
            tp_price    := entry_price + (entry_price - sl_price) * rr_ratio

        // Short: price returns to OB between fib level and top
        if not bull and close >= mid and close <= top and strategy.position_size == 0
            short_signal := true
            entry_price  := close
            sl_price     := top + buf
            tp_price     := entry_price - (sl_price - entry_price) * rr_ratio

// ══════════════════════════════════════════════════════════════
// EXECUTE ORDERS
// ══════════════════════════════════════════════════════════════
qty = f_position_size(math.abs(entry_price - sl_price) / syminfo.mintick, syminfo.pointvalue)
qty := math.max(qty, 1)

if long_signal and not kill_switch
    strategy.entry("Long OB", strategy.long, qty=qty)
    strategy.exit("Long OB Exit", "Long OB",
         stop=sl_price, limit=tp_price,
         trail_points = use_trailing_sl ? close * (trail_pct/100) / syminfo.mintick : na)

if short_signal and not kill_switch
    strategy.entry("Short OB", strategy.short, qty=qty)
    strategy.exit("Short OB Exit", "Short OB",
         stop=sl_price, limit=tp_price,
         trail_points = use_trailing_sl ? close * (trail_pct/100) / syminfo.mintick : na)

// ══════════════════════════════════════════════════════════════
// VISUALS
// ══════════════════════════════════════════════════════════════
plotshape(long_signal,  "Long OB",  shape.triangleup,   location.belowbar, color.new(color.teal,  0), size=size.small)
plotshape(short_signal, "Short OB", shape.triangledown, location.abovebar, color.new(color.red,   0), size=size.small)

// Draw OB zones
if barstate.islast
    for i = 0 to array.size(ob_valid) - 1
        if array.get(ob_valid, i)
            top  = array.get(ob_top,  i)
            bot  = array.get(ob_bot,  i)
            bull = array.get(ob_bull, i)
            col  = bull ? color.new(color.teal, 80) : color.new(color.red, 80)
            box.new(array.get(ob_bar, i), top, bar_index + 10, bot,
                    border_color=col, bgcolor=col)

// Kill switch label
if kill_switch
    label.new(bar_index, high, "⚠ KILL SWITCH", color=color.red, textcolor=color.white, size=size.small)

// Dashboard table
var table dash = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    table.cell(dash, 0, 0, "SentinelFX OB",   text_color=color.teal,  text_size=size.small)
    table.cell(dash, 1, 0, strategy.version,  text_color=color.gray,  text_size=size.tiny)
    table.cell(dash, 0, 1, "Daily DD",         text_color=color.gray,  text_size=size.tiny)
    table.cell(dash, 1, 1, str.tostring(daily_dd, "#.##") + "%",
               text_color = daily_dd >= dd_limit_pct * 0.8 ? color.red : color.green,
               text_size=size.tiny)
    table.cell(dash, 0, 2, "Kill Switch",      text_color=color.gray,  text_size=size.tiny)
    table.cell(dash, 1, 2, kill_switch ? "ARMED 🔴" : "OK 🟢",
               text_color = kill_switch ? color.red : color.green, text_size=size.tiny)
    table.cell(dash, 0, 3, "Net P&L",          text_color=color.gray,  text_size=size.tiny)
    table.cell(dash, 1, 3, str.tostring(strategy.netprofit, "$#,###"),
               text_color = strategy.netprofit >= 0 ? color.green : color.red, text_size=size.tiny)
    table.cell(dash, 0, 4, "Win Rate",         text_color=color.gray,  text_size=size.tiny)
    table.cell(dash, 1, 4, str.tostring(strategy.wintrades / math.max(strategy.closedtrades, 1) * 100, "#.#") + "%",
               text_color=color.white, text_size=size.tiny)
    table.cell(dash, 0, 5, "OBs Active",       text_color=color.gray,  text_size=size.tiny)
    table.cell(dash, 1, 5, str.tostring(array.size(ob_valid)), text_color=color.white, text_size=size.tiny)
