//@version=6
// ══════════════════════════════════════════════════════════════
// SMC LIQUIDITY SWEEP + REVERSAL STRATEGY
// Generated by Architect Agent — 2026-04-27 23:48 UTC
// Signal ID:    preset_sweep
// Alpha Score:  0.840
// ══════════════════════════════════════════════════════════════
strategy("SMC Liquidity Sweep [H4]",
     overlay=true,
     initial_capital=100000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract,
     commission_value=2.0)


// ══════════════════════════════════════════════════════════════
// PROP FIRM RISK ENGINE  — injected by Architect Agent
// Compatible: FTMO · Topstep · MyForexFunds · The5%ers
// ══════════════════════════════════════════════════════════════

// ── Prop Firm Inputs ──────────────────────────────────────────
var g_risk = "Prop Firm Risk"
dd_limit_pct      = input.float(4.5,  "Daily DD Limit %",        group=g_risk, minval=0.5,  maxval=10.0,  step=0.1)
max_loss_pct      = input.float(10.0, "Max Total Loss %",         group=g_risk, minval=1.0,  maxval=20.0,  step=0.5)
risk_per_trade    = input.float(0.5,  "Risk Per Trade %",         group=g_risk, minval=0.1,  maxval=3.0,   step=0.1)
consistency_pct   = input.float(30.0, "Max Single Day % of Obj.", group=g_risk, minval=10.0, maxval=100.0, step=5.0)
anti_detect       = input.bool(true,  "Anti-Detection Mode",      group=g_risk)
account_size      = input.float(100000, "Account Size ($)",       group=g_risk, minval=1000)

// ── Daily DD Tracking ─────────────────────────────────────────
var float day_start_equity = strategy.initial_capital
var float daily_dd         = 0.0
var bool  kill_switch      = false

is_new_day = ta.change(time("D")) != 0
if is_new_day
    day_start_equity := strategy.equity
    kill_switch      := false

daily_dd    := (day_start_equity - strategy.equity) / day_start_equity * 100
total_dd    = (strategy.initial_capital - strategy.equity) / strategy.initial_capital * 100

// Arm kill switch
if daily_dd >= dd_limit_pct or total_dd >= max_loss_pct
    kill_switch := true
    strategy.close_all(comment="KILL_SWITCH")

// ── Position Sizing ───────────────────────────────────────────
f_position_size(sl_ticks, tick_value) =>
    risk_dollars = account_size * (risk_per_trade / 100)
    sl_value     = sl_ticks * tick_value
    sl_value > 0 ? math.floor(risk_dollars / sl_value) : 1

// ── Anti-Detection: randomise entry by ±1-2 ticks ────────────
f_anti_detect_offset() =>
    anti_detect ? (math.random(0, 1) > 0.5 ? syminfo.mintick : -syminfo.mintick) : 0.0


// ══════════════════════════════════════════════════════════════
// LIQUIDITY SWEEP DETECTION
// ══════════════════════════════════════════════════════════════
var g_ls = "Liquidity Sweep Settings"
swing_len     = input.int(10,   "Swing Pivot Length",     group=g_ls, minval=3,   maxval=50)
wick_min_pct  = input.float(0.1,"Min Wick Extension %",   group=g_ls, minval=0.05, maxval=2.0, step=0.05)
require_close = input.bool(true, "Require Close Back Inside", group=g_ls)
equal_hl_tol  = input.float(0.1,"Equal H/L Tolerance %", group=g_ls, minval=0.0,  maxval=1.0, step=0.05)
show_liquidity= input.bool(true, "Show Liquidity Levels",  group=g_ls)

var g_sl = "Stop Loss / Take Profit"
rr_ratio      = input.float(2.5,"R:R Ratio",         group=g_sl, minval=0.5, maxval=10.0, step=0.5)
sl_buffer     = input.int(3,    "SL Buffer (ticks)", group=g_sl, minval=0,   maxval=20)

// ── Swing Highs / Lows ────────────────────────────────────────
swing_high = ta.pivothigh(high, swing_len, swing_len)
swing_low  = ta.pivotlow(low,   swing_len, swing_len)

var float last_swing_high = na
var float last_swing_low  = na
var float prev_swing_high = na
var float prev_swing_low  = na

if not na(swing_high)
    prev_swing_high  := last_swing_high
    last_swing_high  := swing_high

if not na(swing_low)
    prev_swing_low   := last_swing_low
    last_swing_low   := swing_low

// ── Equal Highs / Lows (inducement liquidity) ─────────────────
f_equal_highs() =>
    not na(last_swing_high) and not na(prev_swing_high) and
    math.abs(last_swing_high - prev_swing_high) / prev_swing_high * 100 <= equal_hl_tol

f_equal_lows() =>
    not na(last_swing_low) and not na(prev_swing_low) and
    math.abs(last_swing_low - prev_swing_low) / prev_swing_low * 100 <= equal_hl_tol

// ── BSL Sweep (Buy-Side Liquidity swept → short setup) ────────
f_bsl_sweep() =>
    if na(last_swing_high)
        false
    else
        wick_above   = high > last_swing_high
        wick_size    = (high - math.max(open, close)) / close * 100
        close_inside = close < last_swing_high
        wick_above and wick_size >= wick_min_pct and
             (not require_close or close_inside)

// ── SSL Sweep (Sell-Side Liquidity swept → long setup) ────────
f_ssl_sweep() =>
    if na(last_swing_low)
        false
    else
        wick_below   = low < last_swing_low
        wick_size    = (math.min(open, close) - low) / close * 100
        close_inside = close > last_swing_low
        wick_below and wick_size >= wick_min_pct and
             (not require_close or close_inside)

bsl_sweep = f_bsl_sweep()
ssl_sweep = f_ssl_sweep()

// ── Entry Logic ───────────────────────────────────────────────
buf = sl_buffer * syminfo.mintick + f_anti_detect_offset()

long_signal  = ssl_sweep and strategy.position_size == 0 and not kill_switch
short_signal = bsl_sweep and strategy.position_size == 0 and not kill_switch

long_sl   = last_swing_low  - buf
long_tp   = close + (close - long_sl)  * rr_ratio
short_sl  = last_swing_high + buf
short_tp  = close - (short_sl - close) * rr_ratio

// ── Execute ───────────────────────────────────────────────────
qty = f_position_size(math.abs(close - (long_signal ? long_sl : short_sl)) / syminfo.mintick,
                      syminfo.pointvalue)
qty := math.max(qty, 1)

if long_signal
    strategy.entry("Long Sweep", strategy.long, qty=qty,
                   comment="SSL_SWEEP" + (f_equal_lows() ? "_EQL" : ""))
    strategy.exit("Long Sweep Exit", "Long Sweep", stop=long_sl, limit=long_tp)

if short_signal
    strategy.entry("Short Sweep", strategy.short, qty=qty,
                   comment="BSL_SWEEP" + (f_equal_highs() ? "_EQH" : ""))
    strategy.exit("Short Sweep Exit", "Short Sweep", stop=short_sl, limit=short_tp)

// ── Visuals ───────────────────────────────────────────────────
plotshape(ssl_sweep, "SSL → Long",  shape.arrowup,   location.belowbar, color.green, size=size.normal)
plotshape(bsl_sweep, "BSL → Short", shape.arrowdown, location.abovebar, color.red,   size=size.normal)

bgcolor(bsl_sweep ? color.new(color.red,   90) : na)
bgcolor(ssl_sweep ? color.new(color.green, 90) : na)

// Liquidity level lines
plot(show_liquidity and not na(last_swing_high) ? last_swing_high : na,
     "BSL Level", color.new(color.red,  50), 1, plot.style_line)
plot(show_liquidity and not na(last_swing_low) ? last_swing_low : na,
     "SSL Level", color.new(color.teal, 50), 1, plot.style_line)

if kill_switch
    label.new(bar_index, high, "⚠ KILL SWITCH", color=color.red, textcolor=color.white, size=size.small)
