//@version=6
// ══════════════════════════════════════════════════════════════
// SMC BREAK OF STRUCTURE + CHANGE OF CHARACTER STRATEGY
// Generated by Architect Agent — 2026-04-27 23:48 UTC
// Signal ID:    preset_bos
// Alpha Score:  0.790
// ══════════════════════════════════════════════════════════════
strategy("SMC BOS/CHOCH [M30]",
     overlay=true,
     initial_capital=100000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract,
     commission_value=2.0)


// ══════════════════════════════════════════════════════════════
// PROP FIRM RISK ENGINE  — injected by Architect Agent
// Compatible: FTMO · Topstep · MyForexFunds · The5%ers
// ══════════════════════════════════════════════════════════════

// ── Prop Firm Inputs ──────────────────────────────────────────
var g_risk = "Prop Firm Risk"
dd_limit_pct      = input.float(4.5,  "Daily DD Limit %",        group=g_risk, minval=0.5,  maxval=10.0,  step=0.1)
max_loss_pct      = input.float(10.0, "Max Total Loss %",         group=g_risk, minval=1.0,  maxval=20.0,  step=0.5)
risk_per_trade    = input.float(0.5,  "Risk Per Trade %",         group=g_risk, minval=0.1,  maxval=3.0,   step=0.1)
consistency_pct   = input.float(30.0, "Max Single Day % of Obj.", group=g_risk, minval=10.0, maxval=100.0, step=5.0)
anti_detect       = input.bool(true,  "Anti-Detection Mode",      group=g_risk)
account_size      = input.float(100000, "Account Size ($)",       group=g_risk, minval=1000)

// ── Daily DD Tracking ─────────────────────────────────────────
var float day_start_equity = strategy.initial_capital
var float daily_dd         = 0.0
var bool  kill_switch      = false

is_new_day = ta.change(time("D")) != 0
if is_new_day
    day_start_equity := strategy.equity
    kill_switch      := false

daily_dd    := (day_start_equity - strategy.equity) / day_start_equity * 100
total_dd    = (strategy.initial_capital - strategy.equity) / strategy.initial_capital * 100

// Arm kill switch
if daily_dd >= dd_limit_pct or total_dd >= max_loss_pct
    kill_switch := true
    strategy.close_all(comment="KILL_SWITCH")

// ── Position Sizing ───────────────────────────────────────────
f_position_size(sl_ticks, tick_value) =>
    risk_dollars = account_size * (risk_per_trade / 100)
    sl_value     = sl_ticks * tick_value
    sl_value > 0 ? math.floor(risk_dollars / sl_value) : 1

// ── Anti-Detection: randomise entry by ±1-2 ticks ────────────
f_anti_detect_offset() =>
    anti_detect ? (math.random(0, 1) > 0.5 ? syminfo.mintick : -syminfo.mintick) : 0.0


// ══════════════════════════════════════════════════════════════
// MARKET STRUCTURE
// ══════════════════════════════════════════════════════════════
var g_ms = "Market Structure"
ms_len        = input.int(10,  "Structure Pivot Length", group=g_ms, minval=3, maxval=50)
choch_only    = input.bool(false,"CHOCH Entries Only",   group=g_ms)
confirm_close = input.bool(true, "Confirm with Close",   group=g_ms)

var g_sl = "Stop Loss / Take Profit"
rr_ratio      = input.float(2.0,"R:R Ratio",         group=g_sl, minval=0.5, maxval=10.0)
sl_buffer     = input.int(2,    "SL Buffer (ticks)", group=g_sl, minval=0,   maxval=20)

// ── Structure Pivots ──────────────────────────────────────────
ph = ta.pivothigh(high, ms_len, ms_len)
pl = ta.pivotlow(low,   ms_len, ms_len)

var float last_ph = na
var float last_pl = na
var float prev_ph = na
var float prev_pl = na

if not na(ph)
    prev_ph := last_ph
    last_ph := ph

if not na(pl)
    prev_pl := last_pl
    last_pl := pl

// ── Trend State ───────────────────────────────────────────────
var int trend = 0  // 1=bull, -1=bear, 0=undefined

// BOS Bullish: close above last pivot high (trend continuation)
bos_bull  = not na(last_ph) and close > last_ph and confirm_close

// BOS Bearish: close below last pivot low
bos_bear  = not na(last_pl) and close < last_pl and confirm_close

// CHOCH: close above last_ph while in downtrend (reversal)
choch_bull = not na(last_ph) and trend == -1 and close > last_ph
// CHOCH: close below last_pl while in uptrend (reversal)
choch_bear = not na(last_pl) and trend ==  1 and close < last_pl

if bos_bull or choch_bull
    trend := 1
if bos_bear or choch_bear
    trend := -1

// ── Entry Signals ─────────────────────────────────────────────
buf = sl_buffer * syminfo.mintick + f_anti_detect_offset()

// Long on CHOCH bull (reversal) or BOS bull continuation
take_long  = choch_only ? choch_bull : (bos_bull or choch_bull)
take_short = choch_only ? choch_bear : (bos_bear or choch_bear)

long_signal  = take_long  and strategy.position_size == 0 and not kill_switch
short_signal = take_short and strategy.position_size == 0 and not kill_switch

long_sl  = last_pl - buf
long_tp  = close + (close - long_sl)  * rr_ratio
short_sl = last_ph + buf
short_tp = close - (short_sl - close) * rr_ratio

// ── Execute ───────────────────────────────────────────────────
qty = f_position_size(
    math.abs(close - (long_signal ? long_sl : short_sl)) / syminfo.mintick,
    syminfo.pointvalue)
qty := math.max(qty, 1)

if long_signal
    lbl = choch_bull ? "CHOCH_BULL" : "BOS_BULL"
    strategy.entry("Long MS", strategy.long, qty=qty, comment=lbl)
    strategy.exit("Long MS Exit", "Long MS", stop=long_sl, limit=long_tp)

if short_signal
    lbl = choch_bear ? "CHOCH_BEAR" : "BOS_BEAR"
    strategy.entry("Short MS", strategy.short, qty=qty, comment=lbl)
    strategy.exit("Short MS Exit", "Short MS", stop=short_sl, limit=short_tp)

// ── Visuals ───────────────────────────────────────────────────
plotshape(bos_bull,   "BOS ▲",   shape.labelup,   location.belowbar, color.new(color.teal,  0), text="BOS",   size=size.tiny)
plotshape(bos_bear,   "BOS ▼",   shape.labeldown, location.abovebar, color.new(color.red,   0), text="BOS",   size=size.tiny)
plotshape(choch_bull, "CHOCH ▲", shape.labelup,   location.belowbar, color.new(color.green, 0), text="CHOCH", size=size.small)
plotshape(choch_bear, "CHOCH ▼", shape.labeldown, location.abovebar, color.new(color.orange,0), text="CHOCH", size=size.small)

plot(not na(last_ph) ? last_ph : na, "Last High", color.new(color.red,  60), 1, plot.style_line)
plot(not na(last_pl) ? last_pl : na, "Last Low",  color.new(color.teal, 60), 1, plot.style_line)

if kill_switch
    label.new(bar_index, high, "⚠ KILL SWITCH", color=color.red, textcolor=color.white, size=size.small)
