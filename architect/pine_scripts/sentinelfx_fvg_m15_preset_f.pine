//@version=6
// ══════════════════════════════════════════════════════════════
// SMC FAIR VALUE GAP (FVG) STRATEGY
// Generated by Architect Agent — 2026-04-27 23:48 UTC
// Signal ID:    preset_fvg
// Alpha Score:  0.880
// Market:       NQ
// Timeframe:    M15
// ══════════════════════════════════════════════════════════════
strategy("SMC Fair Value Gap [M15]",
     overlay=true,
     initial_capital=100000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract,
     commission_value=2.0)


// ══════════════════════════════════════════════════════════════
// PROP FIRM RISK ENGINE  — injected by Architect Agent
// Compatible: FTMO · Topstep · MyForexFunds · The5%ers
// ══════════════════════════════════════════════════════════════

// ── Prop Firm Inputs ──────────────────────────────────────────
var g_risk = "Prop Firm Risk"
dd_limit_pct      = input.float(4.5,  "Daily DD Limit %",        group=g_risk, minval=0.5,  maxval=10.0,  step=0.1)
max_loss_pct      = input.float(10.0, "Max Total Loss %",         group=g_risk, minval=1.0,  maxval=20.0,  step=0.5)
risk_per_trade    = input.float(0.5,  "Risk Per Trade %",         group=g_risk, minval=0.1,  maxval=3.0,   step=0.1)
consistency_pct   = input.float(30.0, "Max Single Day % of Obj.", group=g_risk, minval=10.0, maxval=100.0, step=5.0)
anti_detect       = input.bool(true,  "Anti-Detection Mode",      group=g_risk)
account_size      = input.float(100000, "Account Size ($)",       group=g_risk, minval=1000)

// ── Daily DD Tracking ─────────────────────────────────────────
var float day_start_equity = strategy.initial_capital
var float daily_dd         = 0.0
var bool  kill_switch      = false

is_new_day = ta.change(time("D")) != 0
if is_new_day
    day_start_equity := strategy.equity
    kill_switch      := false

daily_dd    := (day_start_equity - strategy.equity) / day_start_equity * 100
total_dd    = (strategy.initial_capital - strategy.equity) / strategy.initial_capital * 100

// Arm kill switch
if daily_dd >= dd_limit_pct or total_dd >= max_loss_pct
    kill_switch := true
    strategy.close_all(comment="KILL_SWITCH")

// ── Position Sizing ───────────────────────────────────────────
f_position_size(sl_ticks, tick_value) =>
    risk_dollars = account_size * (risk_per_trade / 100)
    sl_value     = sl_ticks * tick_value
    sl_value > 0 ? math.floor(risk_dollars / sl_value) : 1

// ── Anti-Detection: randomise entry by ±1-2 ticks ────────────
f_anti_detect_offset() =>
    anti_detect ? (math.random(0, 1) > 0.5 ? syminfo.mintick : -syminfo.mintick) : 0.0


// ══════════════════════════════════════════════════════════════
// FVG DETECTION
// ══════════════════════════════════════════════════════════════
var g_fvg = "FVG Settings"
fvg_lookback  = input.int(20,   "FVG Lookback Bars",    group=g_fvg, minval=5,   maxval=100)
min_fvg_pct   = input.float(0.05,"Min FVG Size %",      group=g_fvg, minval=0.01, maxval=1.0, step=0.01)
entry_at_eq   = input.bool(true, "Entry at 50% EQ",     group=g_fvg)
show_filled   = input.bool(false,"Show Filled FVGs",    group=g_fvg)
require_ob    = input.bool(false,"Require OB Confluence",group=g_fvg)

var g_sl = "Stop Loss / Take Profit"
rr_ratio      = input.float(2.0,"R:R Ratio",        group=g_sl, minval=0.5, maxval=10.0, step=0.5)
sl_buffer     = input.int(2,    "SL Buffer (ticks)",group=g_sl, minval=0,   maxval=20)

// ── 3-Candle FVG Pattern ──────────────────────────────────────
f_bullish_fvg(i) =>
    // Gap between candle[i] low and candle[i+2] high
    gap      = low[i] - high[i+2]
    gap_pct  = gap / high[i+2] * 100
    low[i] > high[i+2] and gap_pct >= min_fvg_pct

f_bearish_fvg(i) =>
    gap      = low[i+2] - high[i]
    gap_pct  = gap / high[i] * 100
    high[i] < low[i+2] and gap_pct >= min_fvg_pct

// ── FVG Arrays ────────────────────────────────────────────────
var float[] fvg_top    = array.new_float()
var float[] fvg_bot    = array.new_float()
var bool[]  fvg_bull   = array.new_bool()
var bool[]  fvg_active = array.new_bool()
var int[]   fvg_bar    = array.new_int()

for i = 2 to fvg_lookback
    if f_bullish_fvg(i)
        array.push(fvg_top,    low[i])
        array.push(fvg_bot,    high[i+2])
        array.push(fvg_bull,   true)
        array.push(fvg_active, true)
        array.push(fvg_bar,    bar_index - i)
    if f_bearish_fvg(i)
        array.push(fvg_top,    low[i+2])
        array.push(fvg_bot,    high[i])
        array.push(fvg_bull,   false)
        array.push(fvg_active, true)
        array.push(fvg_bar,    bar_index - i)

// ── Entry Logic ───────────────────────────────────────────────
long_signal  = false
short_signal = false
sl_price     = 0.0
tp_price     = 0.0

for i = 0 to array.size(fvg_active) - 1
    if array.get(fvg_active, i) and not kill_switch
        top  = array.get(fvg_top,  i)
        bot  = array.get(fvg_bot,  i)
        bull = array.get(fvg_bull, i)
        eq   = bot + (top - bot) * 0.5
        buf  = sl_buffer * syminfo.mintick + f_anti_detect_offset()

        // Mark as filled if price closes through
        if bull and close < bot
            array.set(fvg_active, i, false)
        if not bull and close > top
            array.set(fvg_active, i, false)

        // Long entry at FVG equilibrium (50%)
        if bull and strategy.position_size == 0
            entry_zone = entry_at_eq ? (close <= eq and close >= bot) : (close >= bot and close <= top)
            if entry_zone
                long_signal := true
                sl_price    := bot - buf
                tp_price    := close + (close - sl_price) * rr_ratio

        // Short entry at FVG equilibrium
        if not bull and strategy.position_size == 0
            entry_zone = entry_at_eq ? (close >= eq and close <= top) : (close >= bot and close <= top)
            if entry_zone
                short_signal := true
                sl_price     := top + buf
                tp_price     := close - (sl_price - close) * rr_ratio

// ── Execute ───────────────────────────────────────────────────
qty = f_position_size(math.abs(close - sl_price) / syminfo.mintick, syminfo.pointvalue)
qty := math.max(qty, 1)

if long_signal and not kill_switch
    strategy.entry("Long FVG", strategy.long, qty=qty)
    strategy.exit("Long FVG Exit", "Long FVG", stop=sl_price, limit=tp_price)

if short_signal and not kill_switch
    strategy.entry("Short FVG", strategy.short, qty=qty)
    strategy.exit("Short FVG Exit", "Short FVG", stop=sl_price, limit=tp_price)

// ── Visuals ───────────────────────────────────────────────────
plotshape(long_signal,  "FVG Long",  shape.circle, location.belowbar, color.new(color.teal,  0), size=size.tiny)
plotshape(short_signal, "FVG Short", shape.circle, location.abovebar, color.new(color.orange, 0), size=size.tiny)

if barstate.islast
    for i = 0 to array.size(fvg_active) - 1
        if array.get(fvg_active, i) or show_filled
            top  = array.get(fvg_top,  i)
            bot  = array.get(fvg_bot,  i)
            bull = array.get(fvg_bull, i)
            col  = array.get(fvg_active, i)
                     ? (bull ? color.new(color.teal, 85) : color.new(color.red, 85))
                     : color.new(color.gray, 90)
            box.new(array.get(fvg_bar, i), top, bar_index + 10, bot,
                    border_color=col, bgcolor=col)
            // EQ line
            line.new(array.get(fvg_bar, i), (top+bot)/2, bar_index+10, (top+bot)/2,
                     color=color.new(color.white, 60), style=line.style_dashed, width=1)

if kill_switch
    label.new(bar_index, high, "⚠ KILL SWITCH", color=color.red, textcolor=color.white, size=size.small)
