# ══════════════════════════════════════════════════
# SentinelFX Backend — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════════

# Path to the setup_hunter SQLite database (created by architect/setup_hunter.py)
SENTINEL_DB=../architect/data/setups.db

# Path to the architect module and generated Pine scripts
ARCHITECT_DIR=../architect
PINE_DIR=../architect/pine_scripts

# Executor bridge URL (same server in production, localhost for local dev)
EXECUTOR_URL=http://localhost:8080

# Prop firm name shown in the portal
PROP_FIRM=Topstep SIM

# TradingView webhook security token — must match executor WEBHOOK_SECRET
WEBHOOK_SECRET=sentinel_secret_change_me

# CORS — set to your Vercel frontend URL in production (e.g. https://sentinelfx.vercel.app)
ALLOWED_ORIGIN=*

# Optional: Ollama model for setup_hunter critic
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.1
